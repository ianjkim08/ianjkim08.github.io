---
interface Project {
  title: string;
  description: string;
  tags: string[];
  type: string;
  motif: string;
  githubUrl?: string;
  projectUrl?: string;
}

interface Job {
  title: string;
  company: string;
  date: string;
  description: string;
  url?: string;
}

interface EducationItem {
  title: string;
  school: string;
  date: string;
  description: string;
}

interface Honor {
  title: string;
  organization: string;
  date: string;
  category: string;
  description: string;
}

interface Skill {
  name: string;
  iconUrl: string;
}

interface SkillCategory {
  category: string;
  items: Skill[];
}

interface SocialLinks {
  github: string;
  linkedin: string;
  resume: string;
}

interface Props {
  projects: Project[];
  employment: Job[];
  education: EducationItem[];
  honors: Honor[];
  skills: SkillCategory[];
  socialLinks: SocialLinks;
  about: string;
}

const { projects, employment, education, honors, skills, socialLinks, about } = Astro.props;
---

<div class="folder" data-active-tab="projects">
  <div class="math-motifs" aria-hidden="true">
    <span>E[X]</span>
    <span>argmax</span>
    <span>O(n log n)</span>
    <span>[0,1]^n</span>
  </div>
  <div class="hero-row">
    <div class="headshot-wrapper">
      <img src="/ian_kim.jpg" alt="Ian Kim profile photo" class="headshot" />
    </div>
    <div class="hero-right">
      <div class="folder-header">
        <div class="identity-lockup">
          <div class="identity-stamp">UChicago / CAM + CS</div>
          <h1>Ian Kim</h1>
        </div>
        <div class="header-links">
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode"></button>
          <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="social-link hover-scale-sm" aria-label="GitHub">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href={socialLinks.linkedin} target="_blank" rel="noopener noreferrer" class="social-link hover-scale-sm" aria-label="LinkedIn">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href={socialLinks.resume} target="_blank" rel="noopener noreferrer" class="resume-button hover-scale-sm" aria-label="Resume">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM6 20V4h7v5h5v11H6zm2-6h8v2H8v-2zm0-4h8v2H8v-2zm0 8h5v2H8v-2z"/></svg>
            <span style="transform: translateY(1px);">Resume</span>
          </a>
        </div>
      </div>
      <div class="about-body desktop-only">
        <p class="about-text">{about}</p>
      </div>
    </div>
  </div>
  <div class="about-body mobile-only">
    <p class="about-text">{about}</p>
  </div>
  <div class="coordinate-strip" aria-label="University of Chicago coordinates">
    <span>41.7897 N, 87.5997 W</span>
    <span>mapping systems, models, and histories</span>
  </div>
  <div class="personal-shelf" aria-label="Favorites shelf">
    <div class="shelf-label">Favorites shelf</div>
    <div class="shelf-items">
      <span class="shelf-object shelf-object-book"><i aria-hidden="true"></i><strong>Author</strong> J.R.R. Tolkien</span>
      <span class="shelf-object shelf-object-record"><i aria-hidden="true"></i><strong>Music</strong> Deep house</span>
      <span class="shelf-object shelf-object-ticket"><i aria-hidden="true"></i><strong>Food</strong> Sushi</span>
      <span class="shelf-object shelf-object-cartridge"><i aria-hidden="true"></i><strong>Game</strong> Ocarina of Time</span>
    </div>
  </div>

  <nav class="tab-bar">
    <button class="nav-tab active" data-tab="projects" aria-controls="projects" aria-selected="true">
      <span class="tab-icon" aria-hidden="true"></span>
      <span>Projects</span>
    </button>
    <button class="nav-tab" data-tab="employment" aria-controls="employment" aria-selected="false">
      <span class="tab-icon" aria-hidden="true"></span>
      <span>Experience</span>
    </button>
    <button class="nav-tab" data-tab="education" aria-controls="education" aria-selected="false">
      <span class="tab-icon" aria-hidden="true"></span>
      <span>Education</span>
    </button>
    <button class="nav-tab" data-tab="honors" aria-controls="honors" aria-selected="false">
      <span class="tab-icon" aria-hidden="true"></span>
      <span>Honors</span>
    </button>
    <button class="nav-tab" data-tab="skills" aria-controls="skills" aria-selected="false">
      <span class="tab-icon" aria-hidden="true"></span>
      <span>Skills</span>
    </button>
  </nav>

  <div class="folder-body">

    <div id="projects" class="tab-content" hidden>
      <div class="projects-grid">
        {projects.map((project) => (
          <div class="project-card hover-lift" data-motif={project.motif}>
            <div class="artifact-strip">
              <span>{project.type}</span>
              <span>{project.motif.replace(/-/g, " ")}</span>
            </div>
            <div class="project-postcard" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="project-header">
              {project.projectUrl ? (
                <a href={project.projectUrl} target="_blank" rel="noopener noreferrer" class="project-title-link">
                  <h3>{project.title}</h3>
                </a>
              ) : (
                <h3>{project.title}</h3>
              )}
              {project.githubUrl && (
                <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="title-github-link hover-scale-sm" aria-label="GitHub Repository">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
              )}
            </div>
            <p>{project.description}</p>
            <div class="tech-tags">
              {project.tags.map((tag) => (
                <span class="tech-tag">{tag}</span>
              ))}
            </div>
            {project.projectUrl && (
              <div class="project-actions">
                <a href={project.projectUrl} target="_blank" rel="noopener noreferrer" class="project-visit-link hover-scale-sm">
                  Visit
                  <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3zM5 5h6v2H7v10h10v-4h2v6H5V5z"/></svg>
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
      <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="see-more-link hover-scale">
        See more on GitHub
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>

    <div id="employment" class="tab-content" hidden>
      <div class="timeline">
        {employment.map((job) => (
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>{job.title}</h3>
              {job.url && (
                <a href={job.url} target="_blank" rel="noopener noreferrer" class="timeline-visit-link hover-scale-sm">
                  Visit
                  <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3zM5 5h6v2H7v10h10v-4h2v6H5V5z"/></svg>
                </a>
              )}
            </div>
            <div class="company">{job.company}</div>
            <div class="date">{job.date}</div>
            <p>{job.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div id="education" class="tab-content" hidden>
      <div class="timeline">
        {education.map((item) => (
          <div class="timeline-item">
            <h3>{item.title}</h3>
            <div class="company">{item.school}</div>
            {item.date && <div class="date">{item.date}</div>}
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div id="honors" class="tab-content" hidden>
      <div class="honors-grid">
        {honors.map((honor) => (
          <div class="honor-sticker" data-category={honor.category.toLowerCase().replace(/\s+/g, "-")}>
            <div class="honor-pin" aria-hidden="true"></div>
            <div class="honor-meta">
              <div class="honor-date">{honor.date}</div>
              <div class="honor-category">{honor.category}</div>
            </div>
            <h3>{honor.title}</h3>
            <div class="honor-org">{honor.organization}</div>
            <p>{honor.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div id="skills" class="tab-content" hidden>
      <div class="skills-grid">
        {skills.map((category) => (
          <div class="skill-category">
            <h3>{category.category}</h3>
            <div class="skill-list">
              {category.items.map((skill) => (
                <div class="skill-item-icon" data-skill={skill.name.toLowerCase().replace(/\s+/g, "-")}>
                  <div class="skill-icon">
                    <img src={skill.iconUrl} alt={skill.name} width="28" height="28" loading="lazy" />
                  </div>
                  <span>{skill.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
  <footer class="site-signature">
    <span>built by Ian Kim</span>
    <span>last updated 2026</span>
  </footer>
</div>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.nav-tab');
    const sections = document.querySelectorAll<HTMLElement>('.tab-content');
    const folder = document.querySelector<HTMLElement>('.folder');
    const folderBody = document.querySelector<HTMLElement>('.folder-body');

    function switchTab(targetId: string) {
      folder?.setAttribute('data-active-tab', targetId);
      folderBody?.classList.remove('is-switching');
      void folderBody?.offsetWidth;
      folderBody?.classList.add('is-switching');

      sections.forEach((section) => {
        section.hidden = section.id !== targetId;
      });
      tabs.forEach((tab) => {
        const isActive = tab.dataset.tab === targetId;
        tab.classList.toggle('active', isActive);
        tab.setAttribute('aria-selected', String(isActive));
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        if (tab.dataset.tab) switchTab(tab.dataset.tab);
      });
    });

    switchTab('projects');
  }

  initTabs();

  function initTheme() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    const sunSvg = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
    const moonSvg = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';

    function setTheme(dark: boolean) {
      document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
      // SVG strings are static constants, safe to use innerHTML here
      toggle.innerHTML = dark ? sunSvg : moonSvg;
      localStorage.setItem('theme', dark ? 'dark' : 'light');
    }

    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = saved ? saved === 'dark' : prefersDark;
    setTheme(isDark);

    toggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      setTheme(current !== 'dark');
    });
  }

  initTheme();
</script>
